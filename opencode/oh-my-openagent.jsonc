{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        "opencode/big-pickle"
      ],
      "ultrawork": {
        "model": "opencode-go/kimi-k2.5"
      }
    },
    "hephaestus": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "medium",
      "fallback_models": [
        "github-copilot/gpt-5.2-codex"
      ]
    },
    "prometheus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gpt-5.2",
        "google/gemini-3.1-pro-preview",
        "github-copilot/gemini-3.1-pro-preview",
        "opencode-go/kimi-k2.5"
      ],
      "prompt_append": "Leverage deep & quick agents heavily, always in parallel."
    },
    "oracle": {
      "model": "github-copilot/gpt-5.4",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gpt-5.2",
        "google/gemini-3.1-pro-preview",
        "github-copilot/gemini-3.1-pro-preview"
      ]
    },
    "librarian": {
      "model": "opencode/minimax-m2.5-free",
      "fallback_models": [
        "google/gemini-flash-latest",
        "github-copilot/gemini-3-flash-preview",
        "opencode/big-pickle"
      ]
    },
    "explore": {
      "model": "opencode/minimax-m2.5-free",
      "fallback_models": [
        "github-copilot/grok-code-fast-1",
        "github-copilot/claude-haiku-4.5",
        "opencode/gpt-5-nano"
      ]
    },
    "multimodal-looker": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        "google/gemini-flash-latest",
        "github-copilot/gemini-3-flash-preview",
        "github-copilot/gpt-5.4",
        "github-copilot/gpt-5.2"
      ]
    },
    "metis": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        "github-copilot/gpt-5.4",
        "github-copilot/gpt-5.2",
        "google/gemini-3.1-pro-preview",
        "github-copilot/gemini-3.1-pro-preview"
      ]
    },
    "momus": {
      "model": "github-copilot/gpt-5.4",
      "variant": "medium",
      "fallback_models": [
        "github-copilot/gpt-5.2",
        "google/gemini-3.1-pro-preview",
        "github-copilot/gemini-3.1-pro-preview"
      ]
    },
    "atlas": {
      "model": "github-copilot/gpt-5.4",
      "fallback_models": [
        "github-copilot/gpt-5.2",
        "github-copilot/claude-sonnet-4.6"
      ]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gemini-3.1-pro-preview"
      ]
    },
    "ultrabrain": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "xhigh",
      "fallback_models": [
        "github-copilot/gpt-5.2-codex"
      ]
    },
    "deep": {
      "model": "github-copilot/gpt-5.3-codex",
      "variant": "medium",
      "fallback_models": [
        "github-copilot/gpt-5.2-codex"
      ]
    },
    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gemini-3.1-pro-preview"
      ]
    },
    "quick": {
      "model": "opencode/gpt-5-nano",
      "fallback_models": [
        "opencode/minimax-m2.5-free"
      ]
    },
    "unspecified-low": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        "github-copilot/gpt-5.4",
        "github-copilot/gpt-5.2"
      ]
    },
    "unspecified-high": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        "github-copilot/gpt-5.4",
        "github-copilot/gpt-5.2"
      ]
    },
    "writing": {
      "model": "opencode-go/kimi-k2.5",
      "fallback_models": [
        "github-copilot/gpt-5.4",
        "github-copilot/gpt-5.2"
      ]
    },
    "git": {
      "model": "opencode/gpt-5-nano",
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations."
    }
  },
  "background_task": {
    "providerConcurrency": {
      "google": 10,
      "opencode": 20,
      "github-copilot": 15
    },
    "modelConcurrency": {
      "github-copilot/claude-opus-4.6": 2,
      "opencode/gpt-5-nano": 20
    }
  },
  "sisyphus": {
    "tasks": {
      "storage_path": ".sisyphus/tasks",
      "claude_code_compat": false
    }
  },
  "tmux": {
    "enabled": true,
    "layout": "tiled",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40,
    "isolation": "window"
  },
  "sisyphus_agent": {
    "disabled": false,
    "default_builder_enabled": false,
    "planner_enabled": true,
    "replace_plan": true
  },
  "runtime_fallback": {
    "enabled": true,
    "retry_on_errors": [
      400,
      429,
      503,
      529
    ],
    "max_fallback_attempts": 3,
    "cooldown_seconds": 60,
    "timeout_seconds": 30,
    "notify_on_fallback": true
  },
  "hashline_edit": true,
  "experimental": {
    "truncate_all_tool_outputs": false,
    "aggressive_truncation": true,
    "auto_resume": true,
    "disable_omo_env": false,
    "task_system": true,
    "dynamic_context_pruning": {
      "enabled": false,
      "notification": "detailed",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "protected_tools": [
        "task",
        "todowrite",
        "todoread",
        "lsp_rename",
        "session_read",
        "session_write",
        "session_search"
      ],
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        }
      }
    }
  },
  "git_master": {
    "commit_footer": true,
    "include_co_authored_by": true,
    "git_env_prefix": "GIT_MASTER=1"
  }
}
