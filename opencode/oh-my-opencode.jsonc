{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "agents": {

    "sisyphus": {
      "model": "openrouter/moonshotai/kimi-k2.5",
      "fallback_models": [
        "openrouter/z-ai/glm-5",
        "opencode/big-pickle"
      ],
      "ultrawork": {
        "model": "github-copilot/claude-opus-4.6",
        "variant": "max"
      }
    },

    "hephaestus": {
      "model": "github-copilot/gpt-5.2-codex",
      "variant": "medium",
      "fallback_models": [
        "openrouter/openai/gpt-5.3-codex",
        "openrouter/openai/gpt-5.2-codex"
      ]
    },

    "prometheus": {
      "model": "github-copilot/gpt-5.2",
      "variant": "high",
      "fallback_models": [
        "google/gemini-3.1-pro-preview",
        "github-copilot/gemini-3.1-pro-preview",
        "openrouter/openai/gpt-5.2",
        "openrouter/moonshotai/kimi-k2.5",
        "openrouter/google/gemini-3.1-pro-preview"
      ],
      "prompt_append": "Leverage deep & quick agents heavily, always in parallel."
    },

    "oracle": {
      "model": "github-copilot/gpt-5.2",
      "variant": "high",
      "fallback_models": [
        "google/gemini-3.1-pro-preview",
        "github-copilot/gemini-3.1-pro-preview",
        "openrouter/openai/gpt-5.2",
        "openrouter/google/gemini-3.1-pro-preview"
      ]
    },

    "librarian": {
      "model": "opencode/minimax-m2.5-free",
      "fallback_models": [
        "google/gemini-flash-latest",
        "github-copilot/gemini-3-flash-preview",
        "opencode/big-pickle"
      ]
    },

    "explore":   {
      "model": "opencode/minimax-m2.5-free",
      "fallback_models": [
        "github-copilot/grok-code-fast-1",
        "github-copilot/claude-haiku-4.5",
        "openrouter/openai/gpt-5-nano"
      ]
    },

    "multimodal-looker": {
      "model": "openrouter/moonshotai/kimi-k2.5",
      "fallback_models": [
        "google/gemini-flash-latest",
        "github-copilot/gemini-3-flash-preview",
        "github-copilot/gpt-5.2",
        "openrouter/z-ai/glm-4.5v"
      ]
    },

    "metis": {
      "model": "openrouter/moonshotai/kimi-k2.5",
      "fallback_models": [
        "github-copilot/gpt-5.2",
        "google/gemini-3.1-pro-preview",
        "github-copilot/gemini-3.1-pro-preview",
        "openrouter/openai/gpt-5.2",
        "openrouter/google/gemini-3.1-pro-preview"
      ]
    },

    "momus": {
      "model": "github-copilot/gpt-5.2",
      "variant": "medium",
      "fallback_models": [
        "google/gemini-3.1-pro-preview",
        "github-copilot/gemini-3.1-pro-preview",
        "openrouter/openai/gpt-5.2",
        "openrouter/google/gemini-3.1-pro-preview"
      ]
    },

    "atlas": {
      "model": "openrouter/moonshotai/kimi-k2.5",
      "fallback_models": [
        "github-copilot/claude-sonnet-4.6",
        "github-copilot/gpt-5.2",
        "openrouter/openai/gpt-5.2"
      ]
    }

  },

  "categories": {
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gemini-3.1-pro-preview",
        "openrouter/google/gemini-3.1-pro-preview",
      ]
    },

    "ultrabrain": {
      "model": "github-copilot/gpt-5.2-codex",
      "variant": "xhigh",
      "fallback_models": [
        "openrouter/openai/gpt-5.3-codex",
        "openrouter/openai/gpt-5.2-codex"
      ]
    },

    "deep": {
      "model": "github-copilot/gpt-5.2-codex",
      "variant": "medium",
      "fallback_models": [
        "openrouter/openai/gpt-5.3-codex",
        "openrouter/openai/gpt-5.2-codex"
      ]
    },

    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": [
        "github-copilot/gemini-3.1-pro-preview",
        "openrouter/google/gemini-3.1-pro-preview"
      ]
    },

    "quick": {
      "model": "github-copilot/claude-haiku-4.5",
      "fallback_models": [
        "opencode/gpt-5-nano",
        "opencode/minimax-m2.5-free",
        "openrouter/openai/gpt-5-nano"
      ]
    },

    "unspecified-low": {
      "model": "github-copilot/claude-sonnet-4.6",
      "fallback_models": [
        "github-copilot/gpt-5.2",
        "openrouter/openai/gpt-5.2",
        "openrouter/moonshotai/kimi-k2.5"
      ]
    },

    "unspecified-high": {
      "model": "github-copilot/claude-opus-4.6",
      "variant": "max",
      "fallback_models": [
        "openrouter/moonshotai/kimi-k2.5"
      ]
    },

    "writing": {
      "model": "openrouter/moonshotai/kimi-k2.5"
    },

    "git": {
      "model": "opencode/gpt-5-nano",
      "description": "All git operations",
      "prompt_append": "Focus on atomic commits, clear messages, and safe operations."
    }
  },

  "background_task": {
    "providerConcurrency": {
      "google": 10,
      "opencode": 20,
      "github-copilot": 15,
      "openrouter": 5
    },
    "modelConcurrency": {
      "github-copilot/claude-opus-4.6": 2,
      "openrouter/z-ai/glm-4.5v": 10,
      "opencode/gpt-5-nano": 20
    }
  },

  // "sisyphus_agent": {
  //   "disabled": false,
  //   "default_builder_enabled": false,
  //   "planner_enabled": true,
  //   "replace_plan": true
  // },
  "sisyphus": {
    "tasks": {
      "enabled": true,
      "storage_path": ".sisyphus/tasks",
      "claude_code_compat": false
    }
  },

  // "skills": {
  //   "sources": [
  //     {"path": "./my-skills", "recursive": true},
  //     "https://example.com/skill.yaml"
  //   ],
  //   "enable": ["my-skill"],
  //   "disable": ["other-skill"],
  //   "my-skill": {
  //     "description": "What it does",
  //     "template": "Custom prompt template",
  //     "from": "source-file.ts",
  //     "model": "custom/model",
  //     "agent": "custom-agent",
  //     "subtask": true,
  //     "argument-hint": "usage hint",
  //     "license": "MIT",
  //     "compatibility": ">= 3.0.0",
  //     "metadata": { "author": "Your Name" },
  //     "allowed-tools": ["read", "bash"]
  //   }
  // },

  "experimental": {
    "aggressive_truncation": true,
    "task_system": true
  },
  "tmux": {
    "enabled": false
  }
}
